{
  "name": "sdd-l",
  "version": "4.0.0",
  "description": "SDD-L role launcher package for local CLI agents",
  "license": "MIT",
  "author": "yumat_512",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ytampo/package-sdd-l.git"
  },
  "homepage": "https://github.com/Ytampo/package-sdd-l#readme",
  "bugs": {
    "url": "https://github.com/Ytampo/package-sdd-l/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "sdd-l-prompts",
    "package.json",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "bin": {
    "sdd-l": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli/index.js",
    "sdd-l": "node dist/cli/index.js",
    "postinstall": "node dist/setup/configureNotesTracking.js",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
